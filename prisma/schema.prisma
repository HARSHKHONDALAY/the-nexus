generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin_permission_grants {
  id                                                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_user_id                                      String      @db.Uuid
  permission_id                                      String      @db.Uuid
  granted                                            Boolean     @default(true)
  assigned_by                                        String?     @db.Uuid
  reason                                             String?     @db.VarChar(500)
  created_at                                         DateTime    @default(now()) @db.Timestamptz(6)
  updated_at                                         DateTime    @default(now()) @db.Timestamptz(6)
  users_admin_permission_grants_admin_user_idTousers users       @relation("admin_permission_grants_admin_user_idTousers", fields: [admin_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_admin_permission_grants_assigned_byTousers   users?      @relation("admin_permission_grants_assigned_byTousers", fields: [assigned_by], references: [id], onUpdate: NoAction)
  permissions                                        permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([admin_user_id, permission_id], map: "uk_admin_permission_grants")
  @@index([admin_user_id], map: "idx_admin_permission_grants_admin")
}

model auth_audit_events {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  event_type String   @db.VarChar(80)
  ip_address String?  @db.VarChar(80)
  user_agent String?  @db.VarChar(500)
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_auth_audit_events_created")
  @@index([event_type], map: "idx_auth_audit_events_type")
  @@index([user_id], map: "idx_auth_audit_events_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_reference    String                 @unique(map: "uk_bookings_reference") @db.VarChar(40)
  user_id              String?                @db.Uuid
  event_id             String                 @db.Uuid
  ticket_tier_id       String                 @db.Uuid
  attendee_name        String                 @db.VarChar(160)
  attendee_email       String                 @db.VarChar(320)
  attendee_phone       String?                @db.VarChar(40)
  quantity             Int
  amount_paise         BigInt
  currency             String                 @default("INR") @db.VarChar(8)
  status               String                 @default("PENDING_PAYMENT") @db.VarChar(32)
  payment_deadline_at  DateTime?              @db.Timestamptz(6)
  confirmed_at         DateTime?              @db.Timestamptz(6)
  cancelled_at         DateTime?              @db.Timestamptz(6)
  cancellation_reason  String?                @db.VarChar(600)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  source_type          String                 @default("website") @db.VarChar(40)
  instagram_id         String?                @db.VarChar(120)
  attendee_age         Int?
  attendee_location    String?                @db.VarChar(160)
  occupation           String?                @db.VarChar(160)
  payment_method       String?                @db.VarChar(80)
  notes                String?                @db.VarChar(1000)
  walk_in              Boolean                @default(false)
  platform_events      platform_events        @relation(fields: [event_id], references: [id], onUpdate: NoAction)
  ticket_tiers         ticket_tiers           @relation(fields: [ticket_tier_id], references: [id], onUpdate: NoAction)
  users                users?                 @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  payment_transactions payment_transactions[]
  tickets              tickets[]

  @@index([attendee_name], map: "idx_bookings_attendee_name")
  @@index([event_id], map: "idx_bookings_event")
  @@index([event_id, source_type], map: "idx_bookings_event_source")
  @@index([payment_deadline_at], map: "idx_bookings_payment_deadline")
  @@index([status], map: "idx_bookings_status")
  @@index([user_id], map: "idx_bookings_user")
}

model event_categories {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String            @unique(map: "uk_event_categories_slug") @db.VarChar(120)
  name            String            @db.VarChar(160)
  description     String?           @db.VarChar(800)
  active          Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  platform_events platform_events[]
}

model event_schedules {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String          @db.Uuid
  title           String          @db.VarChar(220)
  description     String?         @db.VarChar(1000)
  starts_at       DateTime        @db.Timestamptz(6)
  ends_at         DateTime?       @db.Timestamptz(6)
  sort_order      Int             @default(0)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  platform_events platform_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model finance_entries {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String?          @db.Uuid
  entry_type      String           @db.VarChar(40)
  amount_paise    BigInt
